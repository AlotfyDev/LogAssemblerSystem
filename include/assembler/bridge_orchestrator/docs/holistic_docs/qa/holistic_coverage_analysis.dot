digraph HolisticCoverageAnalysis {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Arial"];

    // Layer nodes with coverage status
    L1 [label="Layer 1: Core Toolbox\nCoverage: 100%\nStatus: Complete", fillcolor=green];
    L2 [label="Layer 2: Configuration PODs\nCoverage: 87.5%\nStatus: Partial", fillcolor=yellow];
    L3 [label="Layer 3: Stateful Functionality\nCoverage: 91.7%\nStatus: Partial", fillcolor=yellow];
    L4 [label="Layer 4: Composition Layer\nCoverage: 93.3%\nStatus: Partial", fillcolor=yellow];
    L5 [label="Layer 5: Cross-Language Integration\nCoverage: 100%\nStatus: Complete", fillcolor=green];
    L6 [label="Layer 6: Performance Layer\nCoverage: 83.3%\nStatus: Partial", fillcolor=orange];
    L7 [label="Layer 7: Error Handling\nCoverage: 100%\nStatus: Complete", fillcolor=green];
    L8 [label="Layer 8: Testing Framework\nCoverage: 66.7%\nStatus: Incomplete", fillcolor=red];

    // Quality metrics nodes
    Accuracy [label="Accuracy: 92%\n(Target: 95%+)", fillcolor=lightblue];
    Completeness [label="Completeness: 88%\n(Target: 90%+)", fillcolor=lightblue];
    Consistency [label="Consistency: 85%\n(Target: 85%+)", fillcolor=green];
    Usability [label="Usability: 78%\n(Target: 80%+)", fillcolor=yellow];

    // Relationships
    L1 -> L2 [label="Depends on"];
    L2 -> L3 [label="Configures"];
    L3 -> L4 [label="Composes"];
    L4 -> L5 [label="Integrates"];
    L5 -> L6 [label="Optimizes"];
    L6 -> L7 [label="Handles"];
    L7 -> L8 [label="Tests"];

    // Quality connections
    L1 -> Accuracy [style=dashed, color=blue];
    L2 -> Completeness [style=dashed, color=blue];
    L3 -> Consistency [style=dashed, color=blue];
    L4 -> Usability [style=dashed, color=blue];

    // Legend
    subgraph cluster_legend {
        label="Legend";
        Complete [label="Complete (90-100%)", fillcolor=green];
        Partial [label="Partial (70-89%)", fillcolor=yellow];
        Incomplete [label="Incomplete (<70%)", fillcolor=red];
        Target [label="On Target", fillcolor=green];
        NearTarget [label="Near Target", fillcolor=yellow];
    }

    // Title
    labelloc=t;
    label="Bridge Orchestrator Holistic Documentation Coverage Analysis\nValidation Date: 2026-05-06";
}