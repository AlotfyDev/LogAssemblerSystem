digraph BridgeOrchestratorEvolution {
    rankdir=LR;
    node [shape=box, style=filled, fillcolor=lightblue, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=8];

    // Foundation Waves (W01-W05)
    W01 [label="W01: Carrier Layer\nFoundation Primitives\n• TCorrelationToken\n• TPlacementHandle\n• TLoadSignal\nZero-copy primitives", fillcolor=lightcoral];
    W02 [label="W02: Protocol State Layer\nLifecycle Management\n• TBridgeStage\n• TBridgeProtocolState\n• TBridgeTransition\nState machine patterns", fillcolor=lightcoral];
    W03 [label="W03: Participant Layer\nActor Identity\n• TParticipant\n• TParticipantRole\n• TParticipantView\nRole-based classification", fillcolor=lightcoral];
    W04 [label="W04: Channel Layer\nTopology Management\n• TChannel\n• TChannelProfile\n• TChannelBindingPolicy\nProfile-based configuration", fillcolor=lightcoral];
    W05 [label="W05: Obligation Layer\nContract Enforcement\n• TPort\n• TPluginAdapter\n• TObligationSurfacePair\nCRTP-based contracts", fillcolor=lightcoral];

    // Core Framework Waves (W06-W10)
    W06 [label="W06: Binding Layer\nIntegration Points\n• TBinding\n• TBindingProfile\n• TBindingCompatibilityReport\nCompatibility-driven binding", fillcolor=lightyellow];
    W07 [label="W07: Compatibility Layer\nValidation Layer\n• TCompatibilityEvaluator\n• TCompatibilityMatrix\nMatrix-based assessment", fillcolor=lightyellow];
    W08 [label="W08: Session Layer\nRuntime Contexts\n• TSession\n• TSessionPolicy\n• TSessionStatus\nLifecycle-managed environments", fillcolor=lightyellow];
    W09 [label="W09: Protocol Layer\nExecutable Protocols\n• TBridgeProtocol\n• TBridgeProtocolPlan\n• TBridgeProtocolStatus\nStep-by-step execution", fillcolor=lightyellow];
    W10 [label="W10: Bridge Core Layer\nOrchestration Engine\n• TBridge\n• TBridgeConfig\n• TBridgeStatus\nResource-managed orchestration", fillcolor=lightyellow];

    // Advanced Features Waves (W11-W15)
    W11 [label="W11: Registry Layer\nComponent Coordination\n• TCommunicationContextRegistrySet\n• TBoundedRegistry\nRegistry-based coordination", fillcolor=lightgreen];
    W12 [label="W12: Diagnostics Layer\nObservability\n• TDiagnostics\n• TDiagnosticCollector\n• TDiagnosticRecord\nStructured diagnostics", fillcolor=lightgreen];
    W13 [label="W13: Integration Boundary Layer\nExternal Interfaces\n• TIntegrationBoundaryPort\n• TBoundaryHandoffRequest\nBoundary handoff patterns", fillcolor=lightgreen];
    W14 [label="W14: Concrete Bindings Layer\nActual Implementations\n• TLogLevelAPIEnvelopePluginAdapter\n• TWriteSideEnvelopePlacementPort\nLanguage-specific optimizations", fillcolor=lightgreen];
    W15 [label="W15: Integration Skeleton Layer\nEnd-to-End Testing\n• TFirstIntegrationSkeleton\n• TFirstIntegrationSkeletonReport\nComplete workflow validation", fillcolor=lightgreen];

    // Chronological progression edges
    W01 -> W02 [label="Foundation"];
    W02 -> W03 [label="Lifecycle"];
    W03 -> W04 [label="Identity"];
    W04 -> W05 [label="Topology"];
    W05 -> W06 [label="Contracts"];

    W06 -> W07 [label="Integration"];
    W07 -> W08 [label="Validation"];
    W08 -> W09 [label="Runtime"];
    W09 -> W10 [label="Execution"];

    W10 -> W11 [label="Orchestration"];
    W11 -> W12 [label="Coordination"];
    W12 -> W13 [label="Observability"];
    W13 -> W14 [label="Interfaces"];
    W14 -> W15 [label="Implementation"];

    // Key architectural milestones
    subgraph cluster_milestones {
        label="Architectural Milestones";
        style=dashed;
        color=gray;

        milestone1 [label="Zero-Copy Primitives\n(W01)", shape=ellipse, fillcolor=white];
        milestone2 [label="State Machine Patterns\n(W02)", shape=ellipse, fillcolor=white];
        milestone3 [label="Role-Based Architecture\n(W03)", shape=ellipse, fillcolor=white];
        milestone4 [label="Profile-Driven Config\n(W04)", shape=ellipse, fillcolor=white];
        milestone5 [label="CRTP Contracts\n(W05)", shape=ellipse, fillcolor=white];
        milestone6 [label="Compatibility Matrix\n(W07)", shape=ellipse, fillcolor=white];
        milestone7 [label="Registry Coordination\n(W11)", shape=ellipse, fillcolor=white];
        milestone8 [label="End-to-End Integration\n(W15)", shape=ellipse, fillcolor=white];
    }

    // Connect milestones to waves
    W01 -> milestone1 [style=dotted, color=gray];
    W02 -> milestone2 [style=dotted, color=gray];
    W03 -> milestone3 [style=dotted, color=gray];
    W04 -> milestone4 [style=dotted, color=gray];
    W05 -> milestone5 [style=dotted, color=gray];
    W07 -> milestone6 [style=dotted, color=gray];
    W11 -> milestone7 [style=dotted, color=gray];
    W15 -> milestone8 [style=dotted, color=gray];

    // Legend
    subgraph cluster_legend {
        label="Legend";
        style=dashed;
        color=black;

        foundation [label="Foundation\n(W01-W05)", fillcolor=lightcoral, shape=box];
        framework [label="Core Framework\n(W06-W10)", fillcolor=lightyellow, shape=box];
        advanced [label="Advanced Features\n(W11-W15)", fillcolor=lightgreen, shape=box];
        progression [label="Chronological\nProgression", shape=ellipse, fillcolor=white];
        milestone_legend [label="Architectural\nMilestone", shape=ellipse, fillcolor=white];
    }
}