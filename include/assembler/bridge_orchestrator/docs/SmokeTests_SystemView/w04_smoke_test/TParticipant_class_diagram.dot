digraph TParticipant_class_diagram {
    rankdir=TB;
    node [shape=record, fontname="Arial"];

    // Main struct
    TParticipant [label="{TParticipant|std::uint64_t participant_id;\nTParticipantRole role;\nstd::string_view domain;\nstd::string_view family;\nstd::string_view display_name;\nTCorrelationToken correlation;|+ is_valid() const noexcept\n+ is_provider() const noexcept\n+ is_boundary() const noexcept\n+ is_observer() const noexcept\n+ participates_in_exchange() const noexcept\n+ invalid() static constexpr\n+ make(...) static constexpr\n+ operator==(lhs, rhs) const\n+ operator!=(lhs, rhs) const}"];

    // Dependencies
    TParticipant -> TParticipantRole [label="role field"];
    TParticipant -> TCorrelationToken [label="correlation field"];

    // Role classification functions
    TParticipant -> is_provider_role [label="is_provider()"];
    TParticipant -> is_boundary_role [label="is_boundary()"];
    TParticipant -> participates_in_primary_exchange [label="participates_in_exchange()"];

    // Usage in W04
    TParticipant -> TChannel [label="source field"];
    TParticipant -> TChannel [label="target field"];

    // Invisible positioning
    TParticipantRole [shape=plaintext, label="TParticipantRole"];
    TCorrelationToken [shape=plaintext, label="TCorrelationToken"];
    is_provider_role [shape=plaintext, label="is_provider_role()"];
    is_boundary_role [shape=plaintext, label="is_boundary_role()"];
    participates_in_primary_exchange [shape=plaintext, label="participates_in_primary_exchange()"];
    TChannel [shape=plaintext, label="TChannel"];

    // Legend
    subgraph cluster_legend {
        label="TParticipant Structure";
        color=white;
        style=filled;

        legend_data [label="Data Members", shape=rectangle, fillcolor=lightblue];
        legend_methods [label="Instance Methods", shape=rectangle, fillcolor=lightgreen];
        legend_factory [label="Factory Methods", shape=rectangle, fillcolor=yellow];
        legend_w04 [label="W04 Channel Usage", shape=plaintext];
    }
}