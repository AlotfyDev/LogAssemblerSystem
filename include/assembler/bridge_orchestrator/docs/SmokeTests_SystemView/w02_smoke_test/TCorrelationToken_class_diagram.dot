digraph TCorrelationToken_Class_Diagram {
    rankdir=TB
    node [shape=record, style=filled, fillcolor=lightblue]

    // Main struct
    TCorrelationToken [label="{TCorrelationToken\n(struct)|high : uint64_t\l low : uint64_t\l|+ is_valid() : bool\l+ invalid() : TCorrelationToken\l+ from_parts(high, low) : TCorrelationToken\l}", shape=record, fillcolor=lightblue]

    // Free operators
    equality_operators [label="{Equality Operators|\l+ operator==(lhs, rhs) : bool\l+ operator!=(lhs, rhs) : bool\l}", shape=record, fillcolor=lightyellow]

    // Standard library specialization
    hash_specialization [label="{std::hash<TCorrelationToken>|\l+ operator()(token) : size_t\l}", shape=record, fillcolor=lightyellow]

    // Dependencies
    uint64_t_type [label="std::uint64_t", shape=ellipse, fillcolor=lightgrey]
    size_t_type [label="std::size_t", shape=ellipse, fillcolor=lightgrey]

    // Relationships
    TCorrelationToken -> uint64_t_type [label="uses", style=dashed]
    hash_specialization -> TCorrelationToken [label="specializes", style=dashed]
    hash_specialization -> size_t_type [label="returns", style=dashed]

    // Legend
    subgraph cluster_Legend {
        label="Legend"
        style=filled
        fillcolor=white

        StructLegend [label="Struct", shape=record, fillcolor=lightblue]
        FunctionLegend [label="Free Function/Operator", shape=record, fillcolor=lightyellow]
        TypeLegend [label="Data Type", shape=ellipse, fillcolor=lightgrey]
    }
}