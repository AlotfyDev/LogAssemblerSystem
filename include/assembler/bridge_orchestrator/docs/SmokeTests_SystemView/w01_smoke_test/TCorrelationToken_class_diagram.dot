digraph TCorrelationToken_Class_Diagram {
    rankdir=TB
    node [shape=record, style=filled, fillcolor=lightblue]

    // Main class
    TCorrelationToken [label="{TCorrelationToken|high : std::uint64_t\l low : std::uint64_t\l|+ is_valid() : bool\l+ invalid() : TCorrelationToken\l+ from_parts(high_part, low_part) : TCorrelationToken\l+ operator==(lhs, rhs) : bool\l+ operator!=(lhs, rhs) : bool\l}"]

    // Dependencies
    std_uint64_t [label="std::uint64_t", shape=ellipse, fillcolor=lightgrey]
    std_hash [label="std::hash\<TCorrelationToken\>", shape=record, fillcolor=lightyellow, label="{std::hash<TCorrelationToken>|+ operator()(token) : std::size_t\l}"]

    // Relationships
    TCorrelationToken -> std_uint64_t [label="uses", style=dashed]
    std_hash -> TCorrelationToken [label="specializes", style=dashed]

    // Legend
    subgraph cluster_Legend {
        label="Legend"
        style=filled
        fillcolor=white

        ClassLegend [label="Class/Struct", shape=record, fillcolor=lightblue]
        TypeLegend [label="Data Type", shape=ellipse, fillcolor=lightgrey]
        TemplateLegend [label="Template Specialization", shape=record, fillcolor=lightyellow]
    }
}