digraph TIntegrationBoundaryPolicy_Class_Diagram {
    rankdir=TB;
    node [shape=record, style=filled, fillcolor=lightblue];

    // Main policy class
    Policy [label="{TIntegrationBoundaryPolicy\n(Static Policy Class)|+ request_readiness(request) : TReadinessView\l+ supports_outbound_handoff(descriptor) : bool\l+ supports_inbound_handoff(descriptor) : bool\l}", fillcolor=lightcyan];

    // Input types
    Request [label="{TBoundaryHandoffRequest\n(Input)|• correlation : TCorrelationToken\n• target : TIntegrationBoundaryDescriptor\n• material_kind : string_view\n• material_size_hint : uint64_t\n• requires_ordered_handoff : bool\l}", fillcolor=lavender];

    Descriptor [label="{TIntegrationBoundaryDescriptor\n(Input)|• kind : TIntegrationBoundaryKind\n• direction : TIntegrationBoundaryDirection\n• capability_mask : uint32_t\n• boundary_family : string_view\n• correlation : TCorrelationToken\l}", fillcolor=lavender];

    // Output types
    ReadinessView [label="{TReadinessView\n(W01 Reused)|• state : TReadinessState\n• reason : string_view\n• correlation : TCorrelationToken\n• size_hint : uint64_t|+ is_ready() : bool\l+ is_deferred() : bool\l+ is_not_ready() : bool\l+ ready(token, size) : TReadinessView\l+ not_ready(reason, token) : TReadinessView\l+ deferred(reason, token) : TReadinessView\l}", fillcolor=lightgray];

    // Policy logic
    RequestReadinessLogic [label="{request_readiness() Logic|• Check correlation.is_valid()\n• Check target.is_valid()\n• Check target.has(accepts_handoff)\n• Check !material_kind.empty()\n• Check ordering support if required\n• Return ready/deferred/not_ready\l}", shape=note, fillcolor=lightyellow];

    OutboundHandoffLogic [label="{supports_outbound_handoff() Logic|• Check descriptor.is_valid()\n• Check can_emit_across_boundary(direction)\n• Check descriptor.has(accepts_handoff)\n• Return bool\l}", shape=note, fillcolor=lightyellow];

    InboundHandoffLogic [label="{supports_inbound_handoff() Logic|• Check descriptor.is_valid()\n• Check can_receive_across_boundary(direction)\n• Check descriptor.has(accepts_handoff)\n• Return bool\l}", shape=note, fillcolor=lightyellow];

    // Relationships
    Policy -> Request [label="validates"];
    Policy -> Descriptor [label="validates"];

    Policy -> ReadinessView [label="produces"];

    Policy -> RequestReadinessLogic [label="implements"];
    Policy -> OutboundHandoffLogic [label="implements"];
    Policy -> InboundHandoffLogic [label="implements"];

    RequestReadinessLogic -> Request [label="validates"];
    RequestReadinessLogic -> ReadinessView [label="returns"];

    OutboundHandoffLogic -> Descriptor [label="validates"];

    InboundHandoffLogic -> Descriptor [label="validates"];

    // Legend
    subgraph cluster_Legend {
        label="Legend";
        style=filled;
        fillcolor=white;

        LegendMain [label="Main Policy Class", fillcolor=lightcyan];
        LegendInput [label="Input Types", fillcolor=lavender];
        LegendOutput [label="Output Types", fillcolor=lightgray];
        LegendLogic [label="Policy Logic", shape=note, fillcolor=lightyellow];
    }
}</content>
