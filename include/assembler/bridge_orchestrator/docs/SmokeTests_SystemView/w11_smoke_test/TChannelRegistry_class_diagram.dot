    // Main class
    TChannelRegistry [label="{TChannelRegistry<Capacity>|channels : std::array<TChannel, Capacity>\l count : std::size_t\l rejected_insertions : std::uint64_t\l registry_name : std::string_view\l correlation : TCorrelationToken\l|+ is_valid() : bool\l+ full() : bool\l+ find(channel_id) : const TChannel*\l+ contains(channel_id) : bool\l+ register_channel(channel) : bool\l+ snapshot() : TRegistrySnapshot\l+ make(name, token) : TChannelRegistry\l}"]

