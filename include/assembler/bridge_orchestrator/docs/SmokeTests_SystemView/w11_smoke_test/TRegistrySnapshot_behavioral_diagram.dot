digraph TRegistrySnapshot_Behavioral_Diagram {
    rankdir=TB
    node [shape=rectangle, style=filled, fillcolor=lightblue]

    Start [label="TRegistrySnapshot Usage\nin W11 Smoke Test", shape=ellipse, fillcolor=green]

    CreateSnapshot [label="Create Registry Snapshot\nTRegistrySnapshot::make(name, count, capacity, rejected, token)\nCaptures current registry state", fillcolor=yellow]

    ValidateSnapshot [label="Validate Snapshot\nsnapshot.is_valid() - checks name and capacity\nsnapshot.empty() - count == 0\nsnapshot.full() - count >= capacity", fillcolor=lightgreen]

    UseInDiagnostics [label="Use in Diagnostics\nProvides registry statistics for monitoring\nShows capacity usage and rejected insertions", fillcolor=lightcyan]

    End [label="Snapshot operations\ncompleted", shape=ellipse, fillcolor=red]

    Start -> CreateSnapshot
    CreateSnapshot -> ValidateSnapshot
    ValidateSnapshot -> UseInDiagnostics
    UseInDiagnostics -> End
}