    TBridgeProtocolRegistry -> Protocol [label="uses type alias", style=dashed]
    TBridgeProtocolRegistry -> TBoundedRegistry [label="contains", style=dashed]
    TBridgeProtocolRegistry -> TBridgeProtocolId [label="uses for keys", style=dashed]
    TBridgeProtocolRegistry -> TBridgeProtocol [label="registers", style=dashed]
    TBridgeProtocolRegistry -> TRegistryEntry [label="returns", style=dashed]
    TBridgeProtocolRegistry -> TRegistrySnapshot [label="produces", style=dashed]

    // Legend
    subgraph cluster_Legend {
        label="Legend"
        style=filled
        fillcolor=white

        ClassLegend [label="Class/Struct", shape=record, fillcolor=lightblue]
        TypeLegend [label="Template Parameter", shape=ellipse, fillcolor=lightgrey]
        AliasLegend [label="Type Alias", shape=record, fillcolor=lightyellow]
        ComponentLegend [label="Component Type", shape=record, fillcolor=lightyellow]
    }
}