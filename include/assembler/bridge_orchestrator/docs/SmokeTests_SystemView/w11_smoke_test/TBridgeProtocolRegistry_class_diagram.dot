    TBridgeProtocol [label="TBridgeProtocol<PlanCapacity>", shape=record, fillcolor=lightyellow]
    TRegistryEntry [label="{TRegistryEntry<TBridgeProtocolId, Protocol>|...}", shape=record, fillcolor=lightyellow]
    TRegistrySnapshot [label="TRegistrySnapshot", shape=record, fillcolor=lightyellow]

    // Relationships
    TBridgeProtocolRegistry -> Capacity [label="parameterized by", style=dashed]
