digraph TBridgeProtocolRegistry_Class_Diagram {
    rankdir=TB
    node [shape=record, style=filled, fillcolor=lightblue]

    // Main class
    TBridgeProtocolRegistry [label="{TBridgeProtocolRegistry<Capacity, PlanCapacity>|registry : TBoundedRegistry<TBridgeProtocolId, Protocol, Capacity>\l|+ is_valid() : bool\l+ register_protocol(protocol) : bool\l+ find(id) : const TRegistryEntry<TBridgeProtocolId, Protocol>*\l+ contains(id) : bool\l+ snapshot() : TRegistrySnapshot\l+ make(name, token) : TBridgeProtocolRegistry\l}"]

    // Template Parameters
    Capacity [label="Capacity", shape=ellipse, fillcolor=lightgrey]
    PlanCapacity [label="PlanCapacity", shape=ellipse, fillcolor=lightgrey]

    // Type Aliases
    Protocol [label="Protocol = TBridgeProtocol<PlanCapacity>", shape=record, fillcolor=lightyellow]

    // Member Types
