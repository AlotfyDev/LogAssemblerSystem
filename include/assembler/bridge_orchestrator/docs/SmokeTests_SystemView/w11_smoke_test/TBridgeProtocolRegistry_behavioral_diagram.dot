digraph TBridgeProtocolRegistry_Behavioral_Diagram {
    rankdir=TB
    node [shape=rectangle, style=filled, fillcolor=lightblue]

    // Usage in smoke test
    Start [label="TBridgeProtocolRegistry Usage\nin W11 Smoke Test", shape=ellipse, fillcolor=green]

    CreateRegistry [label="Create Protocol Registry\nTBridgeProtocolRegistry<4, 12> protocols{};\nTemplated with capacity and plan capacity", fillcolor=yellow]

    ValidateRegistry [label="Validate Registry\nprotocols.is_valid()\nDelegates to internal TBoundedRegistry\nReturns true", fillcolor=lightgreen]

    CreateProtocol [label="Create Bridge Protocol\nTBridgeProtocol<12> protocol = make_protocol(protocol_id, plan)", fillcolor=yellow]

    RegisterProtocol [label="Register Protocol\nprotocols.register_protocol(protocol)\nRegisters with protocol_id as key\nReturns true", fillcolor=orange]

    LookupProtocol [label="Lookup Protocol\nprotocols.contains(protocol.protocol_id)\nReturns true (protocol found)", fillcolor=lightcyan]

    FindProtocol [label="Find Protocol Entry\nprotocols.find(protocol.protocol_id)\nReturns pointer to TRegistryEntry with protocol data", fillcolor=lightcyan]

    GenerateSnapshot [label="Generate Snapshot\nprotocols.snapshot()\nReturns registry statistics for protocol management", fillcolor=purple]

    End [label="Bridge protocol registry operations\ncompleted with plan capacity management", shape=ellipse, fillcolor=red]

    // Flow
    Start -> CreateRegistry
    CreateRegistry -> ValidateRegistry
    ValidateRegistry -> CreateProtocol
    CreateProtocol -> RegisterProtocol
    RegisterProtocol -> LookupProtocol
    LookupProtocol -> FindProtocol
    FindProtocol -> GenerateSnapshot
    GenerateSnapshot -> End

    // Legend
    subgraph cluster_Legend {
        label="Legend"
        style=filled
        fillcolor=white

        CreationLegend [label="Registry/Protocol Creation", shape=rectangle, fillcolor=yellow]
        ValidationLegend [label="Validation", shape=rectangle, fillcolor=lightgreen]
        RegistrationLegend [label="Registration", shape=rectangle, fillcolor=orange]
        LookupLegend [label="Lookup Operations", shape=rectangle, fillcolor=lightcyan]
        SnapshotLegend [label="Snapshot Generation", shape=rectangle, fillcolor=purple]
    }
}