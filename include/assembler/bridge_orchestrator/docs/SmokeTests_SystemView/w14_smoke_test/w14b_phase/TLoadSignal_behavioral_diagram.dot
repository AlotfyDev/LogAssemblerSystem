digraph TLoadSignal_Class_Diagram {
    rankdir=TB;
    node [shape=record, fontsize=10];
    edge [fontsize=9];

    // Main class
    LoadSignal [label="{TLoadSignal\n(Bridge-visible Load Signal)|+ kind : TLoadSignalKind\l+ correlation : TCorrelationToken\l+ placement : TPlacementHandle\l+ bytes_loaded : uint64_t\l+ note : string_view\l|+ completed() : bool\l+ failed() : bool\l+ started(correlation, handle) : TLoadSignal\l+ completed(correlation, handle, bytes) : TLoadSignal\l+ failed(correlation, handle, note) : TLoadSignal\l}", fillcolor=lightgreen];

    // Kind enum
    LoadSignalKind [label="{TLoadSignalKind\n(Signal Kind)|• unknown\l• load_started\l• load_completed\l• load_failed\l}", fillcolor=lightcyan];

    // Contained types
