    PlacementHandle [label="{TPlacementHandle\n(Handle)|• value : uint64_t\l• correlation : TCorrelationToken\l}", fillcolor=lightcyan];

    StringView [label="{string_view\n(Note)|Optional note or error\l}", fillcolor=orange];

    // Factory methods
    StartedFactory [label="{started factory\n(Start Signal)|+ started(correlation, handle) : TLoadSignal\l• kind = load_started\l• bytes_loaded = 0\l}", fillcolor=lavender];

    CompletedFactory [label="{completed factory\n(Success Signal)|+ completed(correlation, handle, bytes) : TLoadSignal\l• kind = load_completed\l• includes byte count\l}", fillcolor=lavender];

    FailedFactory [label="{failed factory\n(Failure Signal)|+ failed(correlation, handle, note) : TLoadSignal\l• kind = load_failed\l• includes error note\l}", fillcolor=lavender];

    // Query methods
    Completed [label="{completed()\n(Check)|kind == load_completed\l}", fillcolor=lavender];

    Failed [label="{failed()\n(Check)|kind == load_failed\l}", fillcolor=lavender];

    // Usage relationships
    AdapterEmits [label="{TLogLevelAPIEnvelopePluginAdapter\n(Emitter)|emit_load_signal()\nEmits completion signal\l}", fillcolor=lightblue];

    PortReceives [label="{TWriteSideEnvelopePlacementPort\n(Receiver)|receive_load_signal(signal)\nProcesses signal\l}", fillcolor=orange];

    // Relationships
    LoadSignal -> LoadSignalKind [label="contains"];
    LoadSignal -> CorrelationToken [label="contains"];
    LoadSignal -> PlacementHandle [label="contains"];
    LoadSignal -> StringView [label="uses"];

    LoadSignal -> StartedFactory [label="has static"];
    LoadSignal -> CompletedFactory [label="has static"];
    LoadSignal -> FailedFactory [label="has static"];

    LoadSignal -> Completed [label="has method"];
    LoadSignal -> Failed [label="has method"];

    AdapterEmits -> LoadSignal [label="creates"];
