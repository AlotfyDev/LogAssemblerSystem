    Descriptor [label="{TWriteSideRegistryDeliveryMaterialDescriptor|+ correlation : TCorrelationToken\l+ material_id : std::string_view\l+ material_kind : std::string_view\l+ material_size_hint : std::uint64_t\l+ requires_ordered_delivery : bool\l+ registry_boundary : TIntegrationBoundaryDescriptor\l|+ is_valid() const\l+ destination_family() const\l+ make() static\l+ default_log_level_envelope() static\l}", fillcolor=lightsalmon, style=filled];

    // Member types
