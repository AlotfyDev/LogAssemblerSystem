digraph TPlacementRequest_Class_Diagram {
    rankdir=TB;
    node [shape=record, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // Placement request (W01 component)
    PlacementRequest [label="{TPlacementRequest (W01)|material placement request\l+ correlation : TCorrelationToken\l+ material_kind : std::string_view\l+ material_size_hint : std::uint64_t\l+ requires_ordered_delivery : bool\l+ destination_family : std::string_view\l+ make() static\l}", fillcolor=lightgreen, style=filled];

    // Usage in W14C
    Adapter [label="{TWriteSideRegistryDeliveryPluginAdapter|creates placement request\lprepare_placement_request() method\l}", fillcolor=lightsalmon];
    MaterialDescriptor [label="{TWriteSideRegistryDeliveryMaterialDescriptor|provides request parameters\lcorrelation, material info, destination\l}", fillcolor=lightsalmon];

    // Relationships
    Adapter -> PlacementRequest [label="creates"];
    PlacementRequest -> MaterialDescriptor [label="uses data from"];

    // Title
    label="TPlacementRequest (W01) Class Structure and W14C Usage";
    labelloc=t;
}