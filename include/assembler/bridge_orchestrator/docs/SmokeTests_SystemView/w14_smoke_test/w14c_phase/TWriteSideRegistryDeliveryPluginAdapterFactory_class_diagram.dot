    Factory -> Config [label="uses as input"];

    MaterialDescriptor -> CorrelationToken [label="contains"];
    MaterialDescriptor -> MaterialId [label="contains"];
    MaterialDescriptor -> SizeHint [label="contains"];
    MaterialDescriptor -> OrderedFlag [label="contains"];

    // Title
    label="TWriteSideRegistryDeliveryPluginAdapterFactory Class Structure";
    labelloc=t;
}