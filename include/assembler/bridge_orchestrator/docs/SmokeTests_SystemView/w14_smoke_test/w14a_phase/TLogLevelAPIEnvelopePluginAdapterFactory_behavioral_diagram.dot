digraph TLogLevelAPIEnvelopePluginAdapterFactory_Behavioral_Diagram {
    rankdir=TB;
    node [shape=rectangle, style=filled, fillcolor=lightblue];

    // Usage in W14a smoke test
    token_creation [label="TCorrelationToken::from_parts(14u, 1u)\nCreate correlation token"];

    factory_creation [label="TLogLevelAPIEnvelopePluginAdapterFactory::from_fields(\ntoken, \"env-0001\", 128u)\nCreate adapter using factory"];

    adapter_created [label="TLogLevelAPIEnvelopePluginAdapter created\nwith descriptor, config, and state"];

    descriptor_setup [label="TLogLevelEnvelopeDescriptor::make(\ntoken, \"env-0001\", 128u, true, \"write_side\")\nDescriptor created with token, envelope ID, size hint"];

    config_defaults [label="TLogLevelAPIEnvelopePluginAdapterConfig::defaults()\nDefault configuration used"];

    adapter_operations [label="Adapter operations:\n- view()\n- readiness()\n- prepare_placement_request()\n- accept_placement_handle()\n- emit_load_signal()\n- next_destination_request()"];

    success [label="Factory successfully creates working adapter", shape=ellipse, fillcolor=lightgreen];

    // Flow
    token_creation -> factory_creation;
    factory_creation -> adapter_created;

    adapter_created -> descriptor_setup [label="contains"];
    adapter_created -> config_defaults [label="contains"];

    adapter_created -> adapter_operations;

    // Legend
    subgraph cluster_legend {
        label="Legend";
        factory_operation [label="Factory Operation", fillcolor=lightblue];
        creation_step [label="Creation Step"];
        usage [label="Adapter Usage"];
        success_state [label="Success State", shape=ellipse, fillcolor=lightgreen];
    }
}</content>
