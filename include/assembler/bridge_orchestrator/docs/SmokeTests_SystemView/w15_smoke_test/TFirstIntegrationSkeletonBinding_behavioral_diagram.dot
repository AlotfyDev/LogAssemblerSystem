digraph TFirstIntegrationSkeletonBinding_Behavioral_Diagram {
    rankdir=TB;
    node [shape=rectangle, style=rounded, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // W15 smoke test usage
    IncludeBinding [label="Include TFirstIntegrationSkeletonBinding\n- provides aggregate include for W15 skeleton\n- defines availability marker ASCC_W15_FIRST_INTEGRATION_SKELETON_AVAILABLE"];

    AvailabilityCheck [label="Availability Marker Usage:\n- constexpr bool ASCC_W15_FIRST_INTEGRATION_SKELETON_AVAILABLE = true\n- used by build systems and integration tests to detect W15 availability"];

    ComponentAggregation [label="Component Aggregation:\n- aggregates all W15 skeleton components in single include\n- provides stable include surface for downstream integration\n- enables W15 skeleton as coherent integration layer"];

    IntegrationBoundary [label="Integration Boundary Role:\n- serves as boundary between W14A/W14B and W15 integration\n- provides availability marker for conditional compilation\n- enables future waves to depend on stable W15 surface"];

    // Flow connections
    IncludeBinding -> AvailabilityCheck;
    AvailabilityCheck -> ComponentAggregation;
    ComponentAggregation -> IntegrationBoundary;

    // Styling
    IncludeBinding [fillcolor=lightblue];
    AvailabilityCheck [fillcolor=lightyellow];
    ComponentAggregation [fillcolor=lightsalmon];
    IntegrationBoundary [fillcolor=lightgreen];

    // Title
    label="TFirstIntegrationSkeletonBinding Usage in W15 Smoke Test";
    labelloc=t;
}</content>
