digraph TObligationSurfacePair_Behavioral_Diagram {
    rankdir=TB;
    node [shape=rectangle, style=rounded, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    SurfacePairCreation [label="Surface Pair Creation:\n- TFirstIntegrationSkeletonModelPlan::make_surface_pair()\n- creates pair from adapter.view() and port.view()\n- enables adapter-port compatibility validation"];

    CompatibilityValidation [label="Compatibility Validation:\n- surface_pair.is_valid() && supports_primary_placement_flow()\n- validates surface pair construction and placement flow support\n- failure returns early with invalid surface pair note"];

    BindingUsage [label="Binding Declaration Input:\n- surface_pair passed to TFirstIntegrationSkeletonModelPlan::declare_binding()\n- used to validate adapter-port binding compatibility\n- ensures placement flow requirements are met"];

    SurfacePairCreation -> CompatibilityValidation;
    CompatibilityValidation -> BindingUsage [label="valid"];
    CompatibilityValidation -> End [label="invalid"];

    End [label="Surface Pair Invalid", shape=ellipse, fillcolor=lightcoral];

    SurfacePairCreation [fillcolor=lightblue];
    CompatibilityValidation [fillcolor=lightyellow];
    BindingUsage [fillcolor=lightsalmon];

    label="TObligationSurfacePair Usage in W15 Smoke Test (W01 Reused)";
    labelloc=t;
}</content>
