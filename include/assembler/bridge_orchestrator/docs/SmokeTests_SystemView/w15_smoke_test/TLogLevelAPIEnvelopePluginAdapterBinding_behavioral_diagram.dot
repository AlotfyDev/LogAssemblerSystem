digraph TLogLevelAPIEnvelopePluginAdapterBinding_Behavioral_Diagram {
    rankdir=TB;
    node [shape=rectangle, style=rounded, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // W15 smoke test usage
    IncludeBinding [label="Include W14A Binding:\n- #include TLogLevelAPIEnvelopePluginAdapterBinding\n- provides aggregate access to W14A adapter components\n- enables W15 skeleton to use W14A adapter"];

    AdapterCreation [label="Adapter Creation via Factory:\n- TLogLevelAPIEnvelopePluginAdapterFactory::from_fields()\n- correlation_token: TCorrelationToken::from_parts(15u, 1u)\n- envelope_id: 'w15-log-level-envelope'\n- payload_size_hint: 256"];

    ViewValidation [label="View Validation:\n- adapter.view().is_valid()\n- validates adapter view construction\n- used in W15 skeleton view validation phase"];

    SkeletonIntegration [label="W15 Skeleton Integration:\n- adapter used in model declaration (channel creation)\n- adapter used in carrier flow (placement, load signal)\n- provides envelope extraction from Log Level API"];

    // Flow connections
    IncludeBinding -> AdapterCreation;
    AdapterCreation -> ViewValidation;
    ViewValidation -> SkeletonIntegration;

    // Styling
    IncludeBinding [fillcolor=lightblue];
    AdapterCreation [fillcolor=lightyellow];
    ViewValidation [fillcolor=lightsalmon];
    SkeletonIntegration [fillcolor=lightgreen];

    // Title
    label="TLogLevelAPIEnvelopePluginAdapterBinding Usage in W15 Smoke Test (W14A Reused)";
    labelloc=t;
}</content>
