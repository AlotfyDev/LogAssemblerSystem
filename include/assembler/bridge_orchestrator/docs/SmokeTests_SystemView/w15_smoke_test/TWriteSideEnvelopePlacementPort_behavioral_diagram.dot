digraph TWriteSideEnvelopePlacementPort_Behavioral_Diagram {
    rankdir=TB;
    node [shape=rectangle, style=rounded, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // W15 smoke test usage sequence
    PortCreation [label="Port Creation:\n- created via TWriteSideEnvelopePlacementPortFactory::make_default()\n- initialized with default configuration and empty state"];

    ViewAccess [label="View Access:\n- port.view() called for model declaration\n- returns TPortView for channel participant\n- used in TFirstIntegrationSkeletonModelPlan::declare_channel()"];

    ReadinessCheck [label="Readiness Check:\n- port.readiness(placement_request).is_ready() called in carrier flow\n- validates port can accept the placement request\n- checks material compatibility and resource availability"];

    AdmissionDecision [label="Admission Decision:\n- port.admit(placement_request) makes admission decision\n- validates request parameters and correlation\n- returns accepted/rejected with reason"];

    HandleCreation [label="Placement Handle Creation:\n- port.placement_handle(placement_request) creates acceptance handle\n- generates unique handle with correlation token\n- returns handle for adapter to use"];

    LoadSignalReception [label="Load Signal Reception:\n- port.receive_load_signal(load_signal) processes completion signal\n- validates signal correlation and handle matching\n- returns success/failure result"];

    NextDestinationProcessing [label="Next Destination Processing:\n- port.next_destination(next_destination_request) handles routing\n- processes completion reason and next destination logic\n- returns acknowledgment result"];

    // Flow connections
    PortCreation -> ViewAccess;
    ViewAccess -> ReadinessCheck;
    ReadinessCheck -> AdmissionDecision;
    AdmissionDecision -> HandleCreation;
    HandleCreation -> LoadSignalReception;
    LoadSignalReception -> NextDestinationProcessing;

    // Styling by lifecycle phase
    PortCreation [fillcolor=lightblue];
    ViewAccess [fillcolor=lightyellow];
    ReadinessCheck [fillcolor=lightsalmon];
    AdmissionDecision [fillcolor=lightgreen];
    HandleCreation [fillcolor=lightcyan];
    LoadSignalReception [fillcolor=palegreen];
    NextDestinationProcessing [fillcolor=orange];

    // Title
    label="TWriteSideEnvelopePlacementPort Usage in W15 Smoke Test (W14B Reused)";
    labelloc=t;
}</content>
