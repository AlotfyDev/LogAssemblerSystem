digraph TFirstIntegrationSkeleton_Class_Diagram {
    rankdir=TB;
    node [shape=record, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // Main skeleton class
    Skeleton [label="{TFirstIntegrationSkeleton|+ config_ : TFirstIntegrationSkeletonConfig\l+ correlation_ : TCorrelationToken\l|+ TFirstIntegrationSkeleton()\l+ config() const\l+ correlation() const\l+ run()\l}", fillcolor=lightsalmon, style=filled];

    // Member components
    Config [label="{TFirstIntegrationSkeletonConfig|configuration for integration skeleton\lIDs, names, limits, hints\l}", fillcolor=lightblue];
    CorrelationToken [label="{TCorrelationToken|correlation tracking token\lhigh and low parts for uniqueness\l}", fillcolor=lightblue];

    // Collaborating components
    Report [label="{TFirstIntegrationSkeletonReport|comprehensive execution report\lmodel success, flow success, details\l}", fillcolor=lightcyan];
    Adapter [label="{TLogLevelAPIEnvelopePluginAdapter|W14A adapter for envelope extraction\lplacement request, load signal, routing\l}", fillcolor=lightcyan];
    Port [label="{TWriteSideEnvelopePlacementPort|W14B port for envelope placement\lreadiness, admission, handle management\l}", fillcolor=lightcyan];
    Channel [label="{TChannel|communication channel between participants\lsingle adapter single port topology\l}", fillcolor=lightcyan];
    Binding [label="{TBinding|binding between adapter and port\lstrict static one-to-one profile\l}", fillcolor=lightcyan];
    Session [label="{TSession|opened communication session\lstrict declaration policy\l}", fillcolor=lightcyan];
    BridgeProtocol [label="{TBridgeProtocol|envelope placement protocol\lstep-by-step execution plan\l}", fillcolor=lightcyan];
    Bridge [label="{TBridge|bridge model execution container\lbounded model run to terminal\l}", fillcolor=lightcyan];
    SurfacePair [label="{TObligationSurfacePair|adapter and port view pairing\lprimary placement flow support\l}", fillcolor=lightcyan];

    // Bridge carriers
    AdmissionResult [label="{TAdmissionResult|admission operation result\laccepted/rejected with correlation\l}", fillcolor=palegreen];
    PlacementHandle [label="{TPlacementHandle|placement acceptance handle\lcorrelation and handle family\l}", fillcolor=palegreen];
    BridgeResult [label="{TBridgeResult|bridge operation result\lsuccess/failure with correlation\l}", fillcolor=palegreen];
    BridgeCoreResult [label="{TBridgeCoreResult|bridge core execution result\lcompleted/failed with details\l}", fillcolor=palegreen];

    // Relationships
    Skeleton -> Config [label="owns"];
    Skeleton -> CorrelationToken [label="owns"];

    Skeleton -> Report [label="creates"];
    Skeleton -> Adapter [label="creates"];
    Skeleton -> Port [label="creates"];
    Skeleton -> Channel [label="uses"];
    Skeleton -> Binding [label="uses"];
    Skeleton -> Session [label="uses"];
    Skeleton -> BridgeProtocol [label="uses"];
    Skeleton -> Bridge [label="uses"];
    Skeleton -> SurfacePair [label="uses"];

    Skeleton -> AdmissionResult [label="validates"];
    Skeleton -> PlacementHandle [label="validates"];
    Skeleton -> BridgeResult [label="validates"];
    Skeleton -> BridgeCoreResult [label="validates"];

    // Title
    label="TFirstIntegrationSkeleton Class Structure and W15 Usage";
    labelloc=t;
}</content>
