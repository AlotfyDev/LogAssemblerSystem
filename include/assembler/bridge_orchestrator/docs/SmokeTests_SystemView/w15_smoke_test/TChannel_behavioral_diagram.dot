digraph TChannel_Behavioral_Diagram {
    rankdir=TB;
    node [shape=rectangle, style=rounded, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // W15 smoke test usage
    ChannelDeclaration [label="Channel Declaration:\n- TFirstIntegrationSkeletonModelPlan::declare_channel()\n- creates channel with adapter and port participant views\n- uses single adapter single port topology profile\n- channel_id and channel_name from config"];

    ValidationCheck [label="Channel Validation:\n- channel.is_valid() called in skeleton\n- validates channel construction succeeded\n- failure returns early with invalid channel note"];

    BindingUsage [label="Binding Declaration Input:\n- channel passed to TFirstIntegrationSkeletonModelPlan::declare_binding()\n- used as foundation for binding proposal\n- enables adapter-port communication path"];

    // Flow connections
    ChannelDeclaration -> ValidationCheck;
    ValidationCheck -> BindingUsage [label="valid"];
    ValidationCheck -> End [label="invalid"];

    End [label="Channel Invalid", shape=ellipse, fillcolor=lightcoral];

    // Styling
    ChannelDeclaration [fillcolor=lightblue];
    ValidationCheck [fillcolor=lightyellow];
    BindingUsage [fillcolor=lightsalmon];

    // Title
    label="TChannel Usage in W15 Smoke Test (W01 Reused)";
    labelloc=t;
}</content>
