digraph TAdmissionResult_Behavioral_Diagram {
    rankdir=TB;
    node [shape=rectangle, style=rounded, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    AdmissionExecution [label="Admission Execution:\n- port.admit(placement_request) called in carrier flow\n- port evaluates placement request and makes admission decision\n- returns TAdmissionResult with acceptance status"];

    AcceptanceValidation [label="Acceptance Validation:\n- admission.accepted() called in skeleton\n- validates port accepted the placement request\n- failure returns early with admission not accepted note"];

    ReportStorage [label="Report Storage:\n- admission result stored in TFirstIntegrationSkeletonReport\n- provides detailed admission information for debugging\n- correlation token preserved for tracking"];

    AdmissionExecution -> AcceptanceValidation;
    AcceptanceValidation -> ReportStorage [label="accepted"];
    AcceptanceValidation -> End [label="not accepted"];

    End [label="Admission Not Accepted", shape=ellipse, fillcolor=lightcoral];

    AdmissionExecution [fillcolor=lightblue];
    AcceptanceValidation [fillcolor=lightyellow];
    ReportStorage [fillcolor=lightsalmon];

    label="TAdmissionResult Usage in W15 Smoke Test (W01 Reused)";
    labelloc=t;
}</content>
