digraph TCorrelationToken_Behavioral_Diagram {
    rankdir=TB;
    node [shape=rectangle, style=rounded, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // W15 smoke test usage
    TokenCreation [label="Correlation Token Creation:\n- TCorrelationToken::from_parts(15u, 1u)\n- creates token with high=15 (W15), low=1 (first instance)\n- used throughout W15 skeleton for request correlation"];

    SkeletonConstruction [label="Skeleton Construction:\n- passed to TFirstIntegrationSkeletonFactory::from_config_and_token()\n- stored in skeleton for use in model declaration and carrier flow\n- enables correlation tracking across the integration"];

    ModelDeclaration [label="Model Declaration Correlation:\n- passed to all model declaration helpers\n- used in channel, binding, session, protocol, bridge creation\n- enables correlation continuity in model objects"];

    CarrierFlowCorrelation [label="Carrier Flow Correlation:\n- used in adapter creation (correlation token parameter)\n- included in all bridge carriers (placement request, handle, load signal)\n- enables request/response matching in carrier exchange"];

    ValidationCorrelation [label="Correlation Validation:\n- adapter validates handle correlation matches original token\n- port validates signal correlation matches placement correlation\n- ensures operations belong to same integration instance"];

    // Flow connections
    TokenCreation -> SkeletonConstruction;
    SkeletonConstruction -> ModelDeclaration;
    SkeletonConstruction -> CarrierFlowCorrelation;
    CarrierFlowCorrelation -> ValidationCorrelation;

    // Styling
    TokenCreation [fillcolor=lightblue];
    SkeletonConstruction [fillcolor=lightyellow];
    ModelDeclaration [fillcolor=lightsalmon];
    CarrierFlowCorrelation [fillcolor=lightgreen];
    ValidationCorrelation [fillcolor=lightcyan];

    // Title
    label="TCorrelationToken Usage in W15 Smoke Test (W01 Reused)";
    labelloc=t;
}</content>
