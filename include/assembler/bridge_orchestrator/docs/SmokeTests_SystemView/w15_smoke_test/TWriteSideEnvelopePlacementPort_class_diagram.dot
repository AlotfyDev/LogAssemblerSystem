    Port -> AdmissionResult [label="returns"];
    Port -> PlacementHandle [label="returns"];
    Port -> BridgeResult [label="returns"];

    Port -> PlacementRequest [label="accepts"];
    Port -> LoadSignal [label="accepts"];
    Port -> NextDestinationRequest [label="accepts"];

