    // Main port class
    Port [label="{TWriteSideEnvelopePlacementPort|+ view() -> TPortView\l+ readiness(TPlacementRequest) -> TReadinessView\l+ admit(TPlacementRequest) -> TAdmissionResult\l+ placement_handle(TPlacementRequest) -> TPlacementHandle\l+ receive_load_signal(TLoadSignal) -> TBridgeResult\l+ next_destination(TNextDestinationRequest) -> TBridgeResult\l}", fillcolor=lightsalmon, style=filled];

    // Collaborating components
