    std_uint64_t [label="std::uint64_t", shape=ellipse, fillcolor=lightgrey]
    TCorrelationToken [label="TCorrelationToken", shape=record, fillcolor=lightyellow]

    TRegistrySnapshot -> std_string_view [label="uses", style=dashed]
    TRegistrySnapshot -> std_size_t [label="uses", style=dashed]
