    rankdir=TB
    node [shape=record, style=filled, fillcolor=lightblue]

    // Main enum
    TBridgeStage [label="{TBridgeStage\n(enum class)|idle\l session_opening\l channel_resolution\l binding_resolution\l compatibility_check\l adapter_readiness\l request_preparation\l port_readiness\l admission_request\l admission_result\l handle_exchange\l adapter_handle_acceptance\l load_or_delivery_signal\l next_destination\l result_consolidation\l session_closure\l terminal_success\l terminal_rejected\l terminal_failed\l terminal_deferred\l}"]

