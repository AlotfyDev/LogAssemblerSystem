    single_pass_model_run [label="single_pass_model_run()\n- Single pass execution\n- One step only", shape=note, fillcolor=yellow];
    diagnostic_dry_run [label="diagnostic_dry_run(max_steps)\n- Diagnostic mode\n- Full tracing enabled", shape=note, fillcolor=yellow];

    TBridgeConfig -> manual_step [style=dotted];
