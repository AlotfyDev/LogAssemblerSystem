digraph G {
    rankdir=TB;
    node [shape=record, style=filled, fillcolor=lightcoral];

    // TBridgeConfig class
    TBridgeConfig [label="{TBridgeConfig | + run_mode : TBridgeRunMode\l+ budget : TBridgeStepBudget\l+ require_ready_protocol : bool\l+ collect_diagnostic_snapshot : bool\l+ collect_trace_frame : bool\l+ strict_terminal_consistency : bool\l+ config_name : string_view\l|+ is_valid() : bool\l+ should_collect_diagnostics() : bool\l+ manual_step() : TBridgeConfig [static]\l+ bounded_model_run() : TBridgeConfig [static]\l+ single_pass_model_run() : TBridgeConfig [static]\l+ diagnostic_dry_run() : TBridgeConfig [static]\l}"];

    // Dependencies
