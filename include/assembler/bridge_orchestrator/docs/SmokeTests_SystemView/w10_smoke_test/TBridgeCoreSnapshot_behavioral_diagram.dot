digraph G {
    rankdir=TB;
    node [shape=rectangle, style=rounded];

    BRIDGE_SNAPSHOT [label="TBridge::snapshot()"];
    CAPTURE_STATE [label="Capture complete state\n- bridge_id, status, config\n- protocol_view, frame\n- last_issue, correlation, name"];
