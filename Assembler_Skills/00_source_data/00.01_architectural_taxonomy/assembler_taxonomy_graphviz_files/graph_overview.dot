digraph graph_overview {
graph [rankdir=LR, labelloc="t", fontsize=20, fontname="Arial", label="Assembler Taxonomy — Graph Overview"];
node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
edge [fontname="Arial", fontsize=9];
"E-EXT-001" [label="E-EXT-001\nLevel API", fillcolor="#D9ECFF"];
"E-EXT-002" [label="E-EXT-002\nAssemblers Administrator", fillcolor="#FFF3CD"];
"E-EXT-003" [label="E-EXT-003\nPolicy Registry / Policy Source", fillcolor="#FFF3CD"];
"E-EXT-004" [label="E-EXT-004\nMetadata Directive Source", fillcolor="#FFF3CD"];
"E-EXT-005" [label="E-EXT-005\nScaling / Operational Directive Source", fillcolor="#FFF3CD"];
"E-EXT-006" [label="E-EXT-006\nLog Level Records Registry", fillcolor="#E2F0D9"];
"E-EXT-007" [label="E-EXT-007\nReading / Querying Subsystem", fillcolor="#EEEEEE"];
"E-INT-001" [label="E-INT-001\nAssembler Subsystem", fillcolor="#FFE2CC"];
"E-INT-002" [label="E-INT-002\nDispatcher", fillcolor="#FFE2CC"];
"E-INT-003" [label="E-INT-003\nWriting / Feeding Round Manager", fillcolor="#FFE2CC"];
"E-INT-004" [label="E-INT-004\nDispatching / Delivery Round Manager", fillcolor="#FFE2CC"];
"E-INT-005" [label="E-INT-005\nQueue Bundle Agent", fillcolor="#FFE2CC"];
"E-INT-007" [label="E-INT-007\nMetadata Injector", fillcolor="#FFE2CC"];
"E-INT-008" [label="E-INT-008\nTimestamp Stabilizer", fillcolor="#FFE2CC"];
"E-INT-009" [label="E-INT-009\nValidator", fillcolor="#FFE2CC"];
"E-INT-010" [label="E-INT-010\nPolicyAssigner", fillcolor="#FFE2CC"];
"BCO-001" [label="BCO-001\nAssemblerPolicyBundle", fillcolor="#EADCF8"];
"BCO-002" [label="BCO-002\nPolicy Object", fillcolor="#EADCF8"];
"BCO-003" [label="BCO-003\nLog Envelope", fillcolor="#EADCF8"];
"E-EXT-001" -> "E-INT-001" [label="R-EXT-001\ncontent ingress"];
"E-EXT-002" -> "BCO-001" [label="R-EXT-002A\ngovernance/policy contribution"];
"E-EXT-003" -> "BCO-001" [label="R-EXT-002B\npolicy source contribution"];
"BCO-001" -> "E-INT-010" [label="R-POL-001\npolicy bundle intake"];
"E-INT-010" -> "BCO-002" [label="R-POL-002\npolicy object readiness"];
"BCO-002" -> "E-INT-002" [label="R-POL-003"];
"BCO-002" -> "E-INT-008" [label="R-POL-004"];
"BCO-002" -> "E-INT-009" [label="R-POL-005"];
"E-EXT-004" -> "E-INT-007" [label="R-EXT-003\nmetadata directive ingress"];
"E-EXT-005" -> "E-INT-005" [label="R-EXT-004\noperational directive ingress"];
"E-EXT-006" -> "E-INT-002" [label="R-EXT-005\nregistry readiness"];
"E-INT-002" -> "E-EXT-006" [label="R-EXT-006\nenvelope handoff"];
"E-EXT-007" -> "E-INT-001" [label="R-EXT-007\nnon-authority boundary", style=dashed, arrowhead=none];
"E-INT-007" -> "BCO-003" [label="R-CAR-002"];
"E-INT-008" -> "BCO-003" [label="R-CAR-003"];
"BCO-003" -> "E-INT-003" [label="R-CAR-004"];
"E-INT-003" -> "E-INT-004" [label="R-CAR-005"];
"E-INT-004" -> "E-INT-002" [label="R-CAR-006"];
}
