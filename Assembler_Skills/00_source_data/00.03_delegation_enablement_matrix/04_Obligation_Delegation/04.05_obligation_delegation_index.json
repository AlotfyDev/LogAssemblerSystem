    "delivery_flag_grain": "one row per compact delivery-cycle state flag",
    "feedback_report_grain": "one row per detailed dispatcher diagnostic/reporting artifact",
    "json_array_policy": "All multi-value relations are arrays.",
    "csv_array_source_policy": "CSV source files use semicolon-separated canonical IDs.",
    "flag_report_separation_policy": "Delivery-Cycle Flag Set and Dispatcher Feedback Report are separate governed objects with separate sub-responsibility groups.",
    "queue_container_policy": "Waiting lists store Queue Container Identifiers, not Log Level Envelopes.",
    "metadata_policy": "Metadata Injector is schema/directive-governed and must not be assigned policy mechanism hosting."
  },
