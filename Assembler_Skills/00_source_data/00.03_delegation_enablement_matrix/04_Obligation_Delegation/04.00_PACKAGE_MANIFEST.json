{
  "package_id": "04_obligation_delegation",
  "package_name": "Obligation Delegation Package",
  "package_path": "04_obligation_delegation/",
  "release_id": "canonical_delegation_enablement_matrix_v2_release",
  "release_status": "draft_for_structured_local_installation",
  "package_status": "draft_for_file_by_file_delivery",
  "package_sequence": 4,
  "0.1_purpose": {
    "summary": "Defines the obligation-to-entity delegation layer derived from the canonical responsibility delegation matrix.",
    "role": "Expands OBL-CAN obligations, sub-responsibilities, delivery-cycle flags, and dispatcher feedback report obligations into queryable CSV, JSON, and Markdown artifacts.",
    "governing_mapping_law": "Responsibility / Obligation -> Enforcing Entity -> Supporting Entities -> Governed Objects -> Enablement Family -> Surface Type -> Trace"
  },
  "0.2_source_basis": {
    "upstream_reference_files": [
      {
        "file_path": "01_reference_markdown/01.01_Canonical_Delegation_Enablement_Matrix_V2.md",
        "role": "Defines the corrected responsibility and obligation matrix used as the semantic basis for this package."
      },
      {
        "file_path": "01_reference_markdown/01.02_canonical_assignment_principles.md",
        "role": "Defines responsibility vs obligation, delegated entity vs governed object, and enablement assignment principles."
      },
      {
        "file_path": "01_reference_markdown/01.03_corrected_delegation_entities.md",
        "role": "Defines corrected delegation entities and governed artifacts such as Envelope Assembler, ports, Delivery-Cycle Flag Set, and Dispatcher Feedback Report."
      },
      {
        "file_path": "01_reference_markdown/01.04_enablement_families_reference.md",
        "role": "Defines the nine canonical enablement families used by obligation enforcement."
      },
      {
        "file_path": "01_reference_markdown/01.05_gap_closure_delegation_coverage.md",
        "role": "Defines gap closure coverage requirements, especially G-003 flag/report split and G-006 queue-container terminology."
      },
      {
        "file_path": "01_reference_markdown/01.06_REFERENCE_SCHEMA.md",
        "role": "Defines the logical schema classes for obligations, sub-responsibilities, and traceable delegation records."
      },
      {
        "file_path": "02_entity_enablement_indexes/02.07_entity_enablement_index.json",
        "role": "Provides entity, enablement, surface, port, governed object, and policy-consuming component joins."
      },
      {
        "file_path": "03_delegation_matrix/03.01_delegation_matrix_v2.csv",
        "role": "Provides the flat responsibility-to-entity delegation rows from which obligation delegation is aligned."
      },
      {
        "file_path": "03_delegation_matrix/03.04_delegation_matrix_index.json",
        "role": "Provides machine-readable family, row, entity-load, and validation rollups for obligation derivation."
      }
    ],
    "conceptual_source_notes": [
      "Obligation is the enforceable counterpart of responsibility.",
      "Every top-level responsibility row must map to at least one obligation.",
      "Delivery-cycle flags and dispatcher feedback reports must be expanded as separate sub-responsibility groups.",
      "Queue Runtime Layer remains classification-only and must not become an obligation enforcement target.",
      "Metadata Injector remains schema/directive-governed and must not be made a policy-hosting obligation carrier."
    ]
  },
