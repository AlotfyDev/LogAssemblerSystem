  "8.0_query_examples": [
    {
      "query_id": "Q-04-001",
      "query": "Which entity enforces OBL-CAN-025?",
      "target_file": "04_obligation_delegation/04.01_obligation_delegation_matrix_v2.csv",
      "join_key": "obligation_id",
      "expected_primary_entity": "E-INT-002 Dispatcher"
    },
    {
      "query_id": "Q-04-002",
      "query": "Which sub-responsibilities belong to delivery-cycle flags?",
      "target_file": "04_obligation_delegation/04.03_delivery_cycle_flags_delegation.csv",
      "join_key": "parent_responsibility_id",
      "expected_parent": "RSP-CAN-025"
    },
    {
      "query_id": "Q-04-003",
      "query": "Which sub-responsibilities belong to dispatcher feedback reports?",
      "target_file": "04_obligation_delegation/04.04_dispatcher_feedback_reports_delegation.csv",
      "join_key": "parent_responsibility_id",
      "expected_parent": "RSP-CAN-048"
    },
    {
      "query_id": "Q-04-004",
      "query": "Which obligations cover G-003?",
      "target_files": [
        "04_obligation_delegation/04.01_obligation_delegation_matrix_v2.csv",
        "04_obligation_delegation/04.03_delivery_cycle_flags_delegation.csv",
        "04_obligation_delegation/04.04_dispatcher_feedback_reports_delegation.csv"
      ],
      "filter": "gap_trace_ids contains G-003",
      "expected_obligation_ids": [
        "OBL-CAN-025",
        "OBL-CAN-048"
      ]
    },
    {
      "query_id": "Q-04-005",
      "query": "Which obligations protect queue-container terminology?",
      "target_file": "04_obligation_delegation/04.01_obligation_delegation_matrix_v2.csv",
      "filter": "gap_trace_ids contains G-006 OR anti_collapse_rule contains queue-container"
