  "6.0_critical_validation_rules": {
    "6.1_top_level_obligation_coverage": {
      "rule": "Every OBL-CAN-001 through OBL-CAN-049 must appear exactly once in 04.01_obligation_delegation_matrix_v2.csv.",
      "severity": "blocking"
    },
    "6.2_responsibility_obligation_alignment": {
      "rule": "Every obligation row must join to one canonical RSP-CAN responsibility row from package 03.",
      "severity": "blocking"
    },
    "6.3_enforcing_entity_required": {
      "rule": "Every obligation row must define at least one primary enforcing entity.",
      "severity": "blocking"
    },
    "6.4_governed_object_required": {
      "rule": "Every obligation row must define at least one governed object, governed boundary, or governed artifact.",
      "severity": "blocking"
    },
    "6.5_enablement_required": {
      "rule": "Every obligation row must define at least one enablement family.",
      "severity": "blocking"
    },
    "6.6_surface_required": {
      "rule": "Every obligation row must define at least one surface.",
      "severity": "blocking"
    },
    "6.7_no_queue_runtime_layer_delegate": {
      "rule": "QUEUE-RUNTIME-LAYER must not appear as a primary enforcing entity.",
      "severity": "blocking"
    },
    "6.8_metadata_injector_policy_exclusion": {
      "rule": "E-INT-007 Metadata Injector must not be assigned EN-FAM-002 Mechanism Hosting Enablement.",
      "severity": "blocking"
    },
    "6.9_flag_report_separation": {
      "rule": "BCO-013 Delivery-Cycle Flag Set and BCO-014 Dispatcher Feedback Report must remain separate governed objects and must not share the same sub-responsibility rows.",
      "severity": "blocking"
    },
    "6.10_queue_as_container_guard": {
      "rule": "Queue Container must remain the queue-as-container object; no separate runtime container may be introduced.",
      "severity": "blocking"
    },
    "6.11_waiting_list_locator_guard": {
      "rule": "Writing and delivery waiting lists must store Queue Container Identifier, not Log Level Envelope.",
      "severity": "blocking"
    },
    "6.12_occupancy_lifecycle_guard": {
      "rule": "Envelope Slot Occupancy must remain occupancy binding/state and must not imply Log Level Envelope lifecycle ownership.",
      "severity": "blocking"
    }
  },
