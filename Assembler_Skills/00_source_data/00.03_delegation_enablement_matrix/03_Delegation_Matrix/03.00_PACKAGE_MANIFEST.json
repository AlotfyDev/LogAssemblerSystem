  "6.0_validation_rules": {
    "responsibility_coverage": [
      {
        "rule_id": "VAL-03-001",
        "rule": "Every top-level responsibility from RSP-CAN-001 through RSP-CAN-049 must appear exactly once in 03.01_delegation_matrix_v2.csv."
      },
      {
        "rule_id": "VAL-03-002",
        "rule": "Every responsibility must have at least one primary delegated entity."
      },
      {
        "rule_id": "VAL-03-003",
        "rule": "Every responsibility must have at least one enablement family."
      },
      {
        "rule_id": "VAL-03-004",
        "rule": "Every responsibility must have at least one surface classification."
      },
      {
        "rule_id": "VAL-03-005",
        "rule": "Every responsibility must map to at least one obligation ID."
      }
    ],
    "entity_assignment": [
      {
        "rule_id": "VAL-03-006",
        "rule": "E-INT-001 Assembler Subsystem may appear as accountability owner but must not absorb narrow operational delegation where a mature entity exists."
      },
      {
        "rule_id": "VAL-03-007",
        "rule": "QUEUE-RUNTIME-LAYER must not appear as primary delegated entity."
      },
      {
        "rule_id": "VAL-03-008",
        "rule": "Governed objects such as BCO-012, BCO-013, BCO-014, BCO-005, BCO-006, BCO-007, BCO-008, BCO-009, BCO-010, and BCO-011 must not be promoted to actor status."
      }
    ],
    "policy_and_metadata": [
      {
        "rule_id": "VAL-03-009",
        "rule": "Metadata Injector must not be assigned policy-hosting responsibilities or EN-FAM-002."
      },
      {
        "rule_id": "VAL-03-010",
        "rule": "Policy Object must remain a semantic governor and must not become behavior executor."
      },
      {
        "rule_id": "VAL-03-011",
        "rule": "PolicyAssigner must mediate policy assignment but must not replace policy-consuming host components."
      }
    ],
    "ports_and_boundaries": [
      {
        "rule_id": "VAL-03-012",
        "rule": "Envelope Assembler must not replace Assembler Ingress Port."
      },
      {
        "rule_id": "VAL-03-013",
        "rule": "Administrative / Ecosystem Port must not receive normal log content payloads."
      },
      {
        "rule_id": "VAL-03-014",
        "rule": "Registry / Delivery Port must not replace Dispatcher as actor."
      },
      {
        "rule_id": "VAL-03-015",
        "rule": "Dispatcher must remain the final assembler-side handoff actor."
      }
    ],
    "runtime_state": [
      {
        "rule_id": "VAL-03-016",
        "rule": "Queue equals Container; no separate runtime container may be introduced above Queue Container."
      },
      {
        "rule_id": "VAL-03-017",
        "rule": "Writing and delivery waiting lists must store Queue Container Identifiers, not envelopes."
      },
      {
        "rule_id": "VAL-03-018",
        "rule": "Envelope Slot Occupancy must remain a binding/state object and must not imply envelope lifecycle ownership."
      }
    ],
    "feedback_reporting": [
      {
        "rule_id": "VAL-03-019",
        "rule": "Delivery-Cycle Flag Set must remain distinct from Dispatcher Feedback Report."
      },
      {
        "rule_id": "VAL-03-020",
        "rule": "RSP-CAN-025 and RSP-CAN-048 must both delegate to Dispatcher but govern different artifacts."
      }
    ]
  },
