  "10.0_final_canonical_statement": {
    "statement": "The 03_delegation_matrix package is the canonical responsibility-to-entity assignment layer of the release. It must preserve the separation between accountability, primary delegation, support, governed objects, enablement, surfaces, and trace coverage.",
    "non_canonical_if_violated": [
      "a responsibility lacks a primary delegated entity",
      "Queue Runtime Layer is used as a primary delegate",
      "Metadata Injector is treated as policy-consuming",
      "Registry / Delivery Port replaces Dispatcher as actor",
      "Delivery-Cycle Flag Set is conflated with Dispatcher Feedback Report",
      "Queue Container is split from Queue",
      "governed carrier objects are promoted into actors without governance revision"
    ]
  }
