  "0.1_purpose": {
    "summary": "Provide the canonical queryable matrix that maps every top-level responsibility to its primary delegated entity, supporting entities, governed objects, enablement families, surface types, obligations, and trace IDs.",
    "mapping_law": "Responsibility / Obligation → Primary Delegated Entity → Supporting Entities → Governed Objects → Enablement Family → Surface Type → Trace",
    "primary_question_answered": "Given a canonical responsibility, which architectural entity carries it, what objects does it govern, what enablement does it require, and how can the assignment be traced?"
  },
