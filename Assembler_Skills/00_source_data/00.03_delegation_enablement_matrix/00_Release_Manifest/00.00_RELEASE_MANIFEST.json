  "3.1_core_corrections_integrated": [
    {
      "correction_id": "CORR-001",
      "statement": "Metadata Injector is schema/directive-governed and must not be treated as a Policy Object host."
    },
    {
      "correction_id": "CORR-002",
      "statement": "Envelope Assembler is introduced as a client-side composed contract object that composes Validator, Metadata Injector, Timestamp Stabilizer, and envelope assembly routine."
    },
    {
      "correction_id": "CORR-003",
      "statement": "Assembler Ingress Port is introduced as the server-side receiving contract port for Log Level Envelope admission into queue-container slots."
    },
    {
      "correction_id": "CORR-004",
      "statement": "Administrative / Ecosystem Port is introduced for policy bundles, metadata directives, operational directives, and ecosystem control payloads."
    },
    {
      "correction_id": "CORR-005",
      "statement": "Registry / Delivery Port is introduced as the outbound registry-facing contract surface used by the Dispatcher."
    },
    {
      "correction_id": "CORR-006",
      "statement": "Queue Runtime Layer is classification only, not a delegated entity; runtime responsibilities are assigned to Queue Bundle Agent, Single Queue Moderator, and Round Managers."
    },
    {
      "correction_id": "CORR-007",
      "statement": "Delivery-cycle flags and detailed dispatcher feedback reports are separate artifacts and require separate enablements."
    },
    {
      "correction_id": "CORR-008",
      "statement": "Timestamp Stabilizer is no longer a placeholder; it is a mature component participating in all ingress families."
    },
    {
      "correction_id": "CORR-009",
      "statement": "Queue equals Container; no separate runtime container is introduced above Queue Container."
    }
  ],
