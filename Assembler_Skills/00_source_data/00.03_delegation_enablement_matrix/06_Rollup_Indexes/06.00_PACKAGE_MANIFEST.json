  "7.0_validation_rules": [
    {
      "rule_id": "ROLLUP-VAL-001",
      "rule_name": "No New Semantics Rule",
      "severity": "blocking",
      "statement": "The rollup package must not introduce new responsibilities, obligations, entities, governed objects, enablement families, surfaces, contracts, gaps, or doctrines."
    },
    {
      "rule_id": "ROLLUP-VAL-002",
      "rule_name": "Responsibility Coverage Rule",
      "severity": "blocking",
      "statement": "All RSP-CAN-001 through RSP-CAN-049 must be reachable through the rollup index."
    },
    {
      "rule_id": "ROLLUP-VAL-003",
      "rule_name": "Obligation Alignment Rule",
      "severity": "blocking",
      "statement": "All OBL-CAN-001 through OBL-CAN-049 must be reachable and numerically aligned with their corresponding RSP-CAN responsibility."
    },
    {
      "rule_id": "ROLLUP-VAL-004",
      "rule_name": "Gap Closure Reachability Rule",
      "severity": "blocking",
      "statement": "All G-001 through G-007 must be reachable from the rollup index, with covering responsibilities and preserving obligations."
    },
    {
      "rule_id": "ROLLUP-VAL-005",
      "rule_name": "Join Key Fidelity Rule",
      "severity": "blocking",
      "statement": "Join keys must preserve exact canonical casing, prefix grammar, and semicolon-separated CSV multi-value behavior."
    },
    {
      "rule_id": "ROLLUP-VAL-006",
      "rule_name": "Flag / Report Separation Rule",
      "severity": "blocking",
      "statement": "BCO-013 Delivery-Cycle Flag Set and BCO-014 Dispatcher Feedback Report must remain separately queryable."
    },
    {
      "rule_id": "ROLLUP-VAL-007",
      "rule_name": "Queue Runtime Layer Guard",
      "severity": "blocking",
      "statement": "QUEUE-RUNTIME-LAYER must remain classification-only and must not appear as a primary delegated entity."
    },
    {
      "rule_id": "ROLLUP-VAL-008",
      "rule_name": "Metadata Injector Policy Guard",
      "severity": "blocking",
      "statement": "E-INT-007 Metadata Injector must remain schema/directive-governed and must not be treated as a policy host."
    },
    {
      "rule_id": "ROLLUP-VAL-009",
      "rule_name": "Governed Object Actor Guard",
      "severity": "blocking",
      "statement": "BCO-012, BCO-013, and BCO-014 must remain governed artifacts, not primary delegated actors."
    },
    {
      "rule_id": "ROLLUP-VAL-010",
      "rule_name": "Contract Template Doctrine Guard",
      "severity": "blocking",
      "statement": "Contract references must preserve typed/template contract doctrine and must not be converted into runtime COM-interface semantics."
    }
  ],
