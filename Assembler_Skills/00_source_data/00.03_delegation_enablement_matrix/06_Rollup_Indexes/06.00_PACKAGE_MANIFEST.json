      "navigation between package 01 through package 05",
      "downstream relational and graph derivation readiness"
    ],
    "out_of_scope": [
      "final PostgreSQL DDL",
      "runtime implementation",
      "class hierarchy",
      "generated diagrams",
      "deployment topology",
      "final ontology",
      "final expert skill definition"
    ]
