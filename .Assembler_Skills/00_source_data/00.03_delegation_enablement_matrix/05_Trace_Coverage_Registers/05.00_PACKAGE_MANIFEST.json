  "5.0_taxonomy_update_model": {
    "taxonomy_update_categories": [
      {
        "category_id": "TAX-UPD-CAT-001",
        "category_name": "new_delegated_entity",
        "description": "A newly introduced or promoted architectural entity capable of carrying responsibilities."
      },
      {
        "category_id": "TAX-UPD-CAT-002",
        "category_name": "new_governed_artifact",
        "description": "A newly introduced or promoted governed object, carrier, state artifact, or diagnostic artifact."
      },
      {
        "category_id": "TAX-UPD-CAT-003",
        "category_name": "classification_correction",
        "description": "A correction that prevents a classification-only concept from being used as a delegated entity."
      },
      {
        "category_id": "TAX-UPD-CAT-004",
        "category_name": "policy_hosting_exclusion",
        "description": "A correction that excludes an entity from policy-hosting status."
      },
      {
        "category_id": "TAX-UPD-CAT-005",
        "category_name": "runtime_terminology_correction",
        "description": "A correction preserving Queue-as-Container, queue-container locator discipline, or occupancy/lifecycle separation."
      },
      {
        "category_id": "TAX-UPD-CAT-006",
        "category_name": "surface_split",
        "description": "A correction splitting compact state, diagnostic reporting, administrative, managerial, consuming, boundary, contractual, or observability surfaces."
      },
      {
        "category_id": "TAX-UPD-CAT-007",
        "category_name": "contract_surface_decomposition",
        "description": "A correction replacing generic contract layer language with concrete port or contract-side objects."
      },
      {
        "category_id": "TAX-UPD-CAT-008",
        "category_name": "ontology_seed_candidate",
        "description": "A traceable concept suitable for future ontology expert skill derivation."
