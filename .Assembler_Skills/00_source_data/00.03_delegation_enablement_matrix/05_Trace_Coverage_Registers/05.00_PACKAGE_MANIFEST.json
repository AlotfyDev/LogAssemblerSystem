  "4.0_gap_coverage_model": {
    "coverage_definition": {
      "gap_is_covered_only_if": [
        "gap_id is stable and present",
        "closure_statement is recorded",
        "covering responsibility IDs are recorded",
        "preserving obligation IDs are recorded",
        "delegated entity IDs are recorded",
        "governed object IDs are recorded",
        "enablement family IDs are recorded",
        "surface IDs are recorded",
        "contract trace IDs are recorded where applicable",
        "doctrine or taxonomy trace IDs are recorded where applicable",
        "anti-collapse rule is recorded where the gap prevents semantic confusion"
      ],
      "gap_is_not_covered_if": [
        "the gap is only mentioned by name",
        "no delegated entity is assigned",
        "no governed object is identified",
        "no preserving obligation is present",
        "no validation or anti-collapse rule exists for regression-prone gaps"
      ]
    },
