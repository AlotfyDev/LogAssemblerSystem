  "7.0_critical_validation_rules": {
    "7.1_trace_row_coverage": {
      "rule": "Every RSP-CAN-001 through RSP-CAN-049 must appear exactly once in 05.01_delegation_trace_v2.csv.",
      "severity": "blocking"
    },
    "7.2_obligation_trace_alignment": {
      "rule": "Every trace row must include at least one OBL-CAN obligation aligned with the responsibility row.",
      "severity": "blocking"
    },
    "7.3_gap_closure_completeness": {
      "rule": "Every G-001 through G-007 gap must appear exactly once in 05.02_gap_closure_coverage_v2.csv.",
      "severity": "blocking"
    },
    "7.4_gap_not_covered_by_mention_only": {
      "rule": "A gap row is invalid if it lacks covering responsibilities, preserving obligations, delegated entities, governed objects, enablement families, and surfaces.",
      "severity": "blocking"
    },
    "7.5_contract_trace_required": {
      "rule": "Every canonical contract used by a responsibility family must appear in 05.03_contract_to_responsibility_to_entity_trace.csv.",
      "severity": "blocking"
    },
    "7.6_new_entity_register_completeness": {
      "rule": "E-INT-011, E-INT-012, E-INT-013, E-INT-014, BCO-012, BCO-013, and BCO-014 must each appear in 05.05_new_entities_register.csv.",
      "severity": "blocking"
    },
    "7.7_queue_runtime_layer_exclusion": {
      "rule": "QUEUE-RUNTIME-LAYER may appear only as classification correction, never as primary delegated entity.",
      "severity": "blocking"
    },
    "7.8_metadata_injector_policy_exclusion": {
      "rule": "Metadata Injector must be registered as policy-hosting excluded and must not be traced as EN-FAM-002 mechanism host.",
      "severity": "blocking"
    },
    "7.9_flag_report_separation": {
      "rule": "BCO-013 Delivery-Cycle Flag Set and BCO-014 Dispatcher Feedback Report must have separate trace records and must not be conflated.",
      "severity": "blocking"
    },
    "7.10_queue_container_locator_guard": {
      "rule": "Waiting-list trace rows must reference Queue Container Identifier as locator and must not treat waiting lists as envelope stores.",
      "severity": "blocking"
    },
    "7.11_occupancy_lifecycle_guard": {
      "rule": "Envelope Slot Occupancy must be traced as occupancy binding/state, not as Log Level Envelope lifecycle ownership.",
      "severity": "blocking"
    },
    "7.12_port_actor_distinction": {
      "rule": "Registry / Delivery Port must be traced as contract surface; Dispatcher remains actor for outbound delivery.",
      "severity": "blocking"
    },
    "7.13_contract_template_doctrine": {
      "rule": "Contract trace rows must preserve typed/template contract doctrine and must not convert contracts into runtime COM interfaces.",
      "severity": "blocking"
    }
  },
