    "downstream_use": [
      "responsibility delegation matrix",
      "obligation delegation matrix",
      "trace coverage registers",
      "rollup indexes",
      "future PostgreSQL derivation"
    ]
  },
  "0.2_index_rules": {
    "join_grain": "one entity record with nested enablement memberships",
    "canonical_entity_key": "entity_id",
    "canonical_enablement_key": "enablement_family_id",
    "array_policy": "All multi-value relations are represented as arrays, not delimited strings.",
    "governed_object_policy": "Governed objects must remain in governed_object_ids and must not be promoted into delegated entity roles unless a later taxonomy revision explicitly promotes them.",
    "classification_policy": "Classification-only layers may appear for analysis but must not carry enablement as primary responsibility carriers.",
    "metadata_injector_policy": "Metadata Injector must not be assigned EN-FAM-002."
  },
